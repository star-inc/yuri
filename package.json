    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "lowdb": "^7.0.1",
    "quickjs-emscripten": "^0.32.0",
    "tavily": "^1.0.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.17.0",
